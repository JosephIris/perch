{
  "name": "perch-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "WebView2-hosted chrome + xterm.js renderer for perch",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "node run-tests.mjs",
    "build:harness": "esbuild src/harness.ts --bundle --format=iife --target=es2022 --outfile=../../design-loop/harness.js --loader:.css=css --external:/fonts/*"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-search": "^0.15.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
