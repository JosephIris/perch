<ui:FluentWindow x:Class="CmuxWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CmuxWin"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:term="clr-namespace:EasyWindowsTerminalControl;assembly=EasyWindowsTerminalControl"
        mc:Ignorable="d"
        Title="cmux"
        Icon="/Assets/cmux.ico"
        Height="640" Width="1040"
        MinHeight="360" MinWidth="640"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="Transparent"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <ui:FluentWindow.InputBindings>
        <!-- Zoom: increase/decrease font size in all panes (Windows Terminal convention). -->
        <KeyBinding Modifiers="Ctrl" Key="OemPlus"
                    Command="{Binding ZoomInCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="OemPlus"
                    Command="{Binding ZoomInCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl" Key="OemMinus"
                    Command="{Binding ZoomOutCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl" Key="D0"
                    Command="{Binding ZoomResetCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <!-- Pane splits. -->
        <KeyBinding Modifiers="Ctrl+Shift" Key="D"
                    Command="{Binding SplitRightCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="S"
                    Command="{Binding SplitDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="W"
                    Command="{Binding CloseActivePaneCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Key="F2"
                    Command="{Binding RenameActiveSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <!-- URL palette: list every URL in the active pane's buffer. -->
        <KeyBinding Modifiers="Ctrl+Shift" Key="U"
                    Command="{Binding ShowUrlPaletteCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
    </ui:FluentWindow.InputBindings>

    <ui:FluentWindow.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <local:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrush" />

        <DataTemplate x:Key="SessionItemTemplate" DataType="{x:Type local:Session}">
            <Grid Margin="8,12,8,12">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Rename" Click="OnRenameMenuClick" />
                        <MenuItem Header="Close session" Click="OnCloseSessionMenuClick" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:FontIcon Grid.Column="0"
                             Glyph="&#xE756;"
                             FontFamily="{StaticResource Type.Family.Icons}"
                             FontSize="14"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Top"
                             HorizontalAlignment="Left"
                             Margin="0,2,0,0" />

                <StackPanel Grid.Column="1" Orientation="Vertical">
                    <!-- Title swaps between TextBlock and TextBox based on IsEditing -->
                    <Grid>
                        <TextBlock Text="{Binding Title}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Type.BodyStrong}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource Type.Family}"
                                 FontSize="{StaticResource Type.Size.Body}"
                                 FontWeight="SemiBold"
                                 Padding="0"
                                 Margin="-2,0,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 KeyDown="OnRenameTextBoxKeyDown"
                                 LostFocus="OnRenameTextBoxLostFocus"
                                 Loaded="OnRenameTextBoxLoaded">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding DisplayShell}"
                                   Style="{StaticResource Type.Caption}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastActivityRelative}"
                                   Style="{StaticResource Type.Caption}"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="8,0,0,0" />
                    </Grid>

                    <!-- Workspace state chips pushed by `cmux status` / `cmux meta`.
                         Hidden as a group unless any agent has reported something.
                         WrapPanel so chips spill to a second line when the
                         sidebar is narrow (working pill + branch + 2 ports
                         exceeds 200px). Per-chip Margin uses bottom spacing
                         so wrapped rows have breathing room. -->
                    <WrapPanel Margin="0,6,0,0"
                               Visibility="{Binding HasAgentMeta, Converter={StaticResource BoolToVisibility}}">
                        <Border Style="{StaticResource Cmux.SidebarPill}"
                                Background="{Binding AgentStateBrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                                Visibility="{Binding HasAgentState, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,4,4">
                            <TextBlock Text="{Binding AgentStateText}"
                                       Style="{StaticResource Cmux.SidebarPillText}" />
                        </Border>
                        <Border Style="{StaticResource Cmux.SidebarBadge}"
                                Visibility="{Binding HasBranch, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,4,4">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xF1D3;"
                                             FontFamily="{StaticResource Type.Family.Icons}"
                                             FontSize="10"
                                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,3,0" />
                                <TextBlock Text="{Binding Branch}"
                                           Style="{StaticResource Cmux.SidebarBadgeText}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="80" />
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Ports}"
                                      Visibility="{Binding HasPorts, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Cmux.SidebarBadge}"
                                            Margin="0,0,4,4">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Cmux.SidebarBadgeText}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>

                    <!-- OSC 9 notification: third line, hidden unless HasNotification.
                         Colored dot is keyed off Session.NotificationDotBrush which
                         maps Level → theme brush resource key. -->
                    <Grid Margin="0,6,0,0"
                          Visibility="{Binding HasNotification, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0"
                                 Width="6" Height="6"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"
                                 Fill="{Binding NotificationDotBrush, Converter={StaticResource ResourceKeyToBrush}}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding NotificationText}"
                                   Style="{StaticResource Type.Caption}"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style x:Key="SessionListItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnSessionItemMouseDown" />
            <EventSetter Event="PreviewMouseMove" Handler="OnSessionItemMouseMove" />
            <Setter Property="AllowDrop" Value="True" />
            <EventSetter Event="Drop" Handler="OnSessionItemDrop" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <!-- Pill background. Subtle gray when selected/hovered;
                                 transparent at rest so Mica reads through. -->
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Radius.Card}"
                                    SnapsToDevicePixels="True" />
                            <!-- Win11 Fluent nav-item accent: a thin vertical
                                 stripe at the inner-left of the pill, visible
                                 only when selected. Inset top/bottom so the
                                 rounded pill corners still read. -->
                            <Border x:Name="AccentStripe"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,10"
                                    CornerRadius="1.5"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    Visibility="Collapsed"
                                    SnapsToDevicePixels="True" />
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <!-- Selected wins because it's declared after IsMouseOver. -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                <Setter TargetName="AccentStripe" Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource GridLength.SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource GridLength.TitleBarHeight}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2"
                     Title=""
                     ShowMaximize="True" />

        <StackPanel Grid.Row="0" Grid.Column="0"
                    Orientation="Horizontal"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    IsHitTestVisible="False">
            <ui:FontIcon Glyph="&#xE756;"
                         FontFamily="{StaticResource Type.Family.Icons}"
                         FontSize="14"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0" />
            <TextBlock Text="cmux"
                       Style="{StaticResource Type.Caption}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0"
                Background="Transparent"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ui:ListView Grid.Row="0"
                             x:Name="SessionList"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="{StaticResource Thickness.S08}"
                             ItemContainerStyle="{StaticResource SessionListItemStyle}"
                             ItemTemplate="{StaticResource SessionItemTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch"
                             AllowDrop="True"
                             SelectionChanged="OnSessionSelectionChanged" />

                <Border Grid.Row="1"
                        Padding="{StaticResource Thickness.S08}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:DropDownButton x:Name="NewSessionButton"
                                           Grid.Column="0"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left">
                            <ui:DropDownButton.Content>
                                <TextBlock Text="New session" />
                            </ui:DropDownButton.Content>
                            <ui:DropDownButton.Flyout>
                                <ContextMenu x:Name="NewSessionFlyout" />
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                        <ui:Button x:Name="SettingsButton"
                                   Grid.Column="1"
                                   Appearance="Transparent"
                                   ToolTip="Settings"
                                   MinWidth="32"
                                   Padding="6"
                                   Margin="4,0,0,0"
                                   Click="OnSettingsClick">
                            <ui:FontIcon Glyph="&#xE713;"
                                         FontFamily="{StaticResource Type.Family.Icons}"
                                         FontSize="14"
                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </ui:Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid x:Name="TerminalHost" />

            <!-- Anchor: zero-size element above which the Popup positions itself.
                 The Popup uses its own top-level HWND so it can overlay the
                 native conhost HwndHost (WPF airspace would otherwise hide it).
                 Anchored bottom-center, sitting 24px above the status bar. -->
            <FrameworkElement x:Name="ToastAnchor"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Bottom"
                              Width="1" Height="1"
                              Margin="0,0,0,24" />
            <Popup x:Name="ToastPopup"
                   PlacementTarget="{Binding ElementName=ToastAnchor}"
                   Placement="Center"
                   AllowsTransparency="True"
                   StaysOpen="True"
                   Focusable="False"
                   IsOpen="False">
                <Border x:Name="ToastHost"
                        Padding="14,8"
                        CornerRadius="{StaticResource Radius.Card}"
                        Background="{DynamicResource Cmux.Toast.Background}"
                        BorderBrush="{DynamicResource Cmux.Toast.Border}"
                        BorderThickness="1"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon x:Name="ToastIcon"
                                     Glyph="&#xE8C8;"
                                     FontFamily="{StaticResource Type.Family.Icons}"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     Foreground="{DynamicResource Cmux.Toast.Foreground}" />
                        <TextBlock x:Name="ToastText"
                                   Style="{StaticResource Type.Body}"
                                   Foreground="{DynamicResource Cmux.Toast.Foreground}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="Transparent"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText"
                       Style="{StaticResource Type.Caption}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0" />
        </Border>
    </Grid>
</ui:FluentWindow>
