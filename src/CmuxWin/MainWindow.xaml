<ui:FluentWindow x:Class="CmuxWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CmuxWin"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:term="clr-namespace:EasyWindowsTerminalControl;assembly=EasyWindowsTerminalControl"
        mc:Ignorable="d"
        Title="cmux"
        Icon="/Assets/cmux.ico"
        Height="640" Width="1040"
        MinHeight="360" MinWidth="640"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="Transparent"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <ui:FluentWindow.InputBindings>
        <!-- Zoom: increase/decrease font size in all panes (Windows Terminal convention). -->
        <KeyBinding Modifiers="Ctrl" Key="OemPlus"
                    Command="{Binding ZoomInCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="OemPlus"
                    Command="{Binding ZoomInCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl" Key="OemMinus"
                    Command="{Binding ZoomOutCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl" Key="D0"
                    Command="{Binding ZoomResetCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <!-- Pane splits. -->
        <KeyBinding Modifiers="Ctrl+Shift" Key="D"
                    Command="{Binding SplitRightCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="S"
                    Command="{Binding SplitDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="W"
                    Command="{Binding CloseActivePaneCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Key="F2"
                    Command="{Binding RenameActiveSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
    </ui:FluentWindow.InputBindings>

    <ui:FluentWindow.Resources>
        <DataTemplate x:Key="SessionItemTemplate" DataType="{x:Type local:Session}">
            <Grid Margin="8,12,8,12">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Rename" Click="OnRenameMenuClick" />
                        <MenuItem Header="Close session" Click="OnCloseSessionMenuClick" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:FontIcon Grid.Column="0"
                             Glyph="&#xE756;"
                             FontFamily="{StaticResource Type.Family.Icons}"
                             FontSize="14"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Top"
                             HorizontalAlignment="Left"
                             Margin="0,2,0,0" />

                <StackPanel Grid.Column="1" Orientation="Vertical">
                    <!-- Title swaps between TextBlock and TextBox based on IsEditing -->
                    <Grid>
                        <TextBlock Text="{Binding Title}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Type.BodyStrong}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource Type.Family}"
                                 FontSize="{StaticResource Type.Size.Body}"
                                 FontWeight="SemiBold"
                                 Padding="0"
                                 Margin="-2,0,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 KeyDown="OnRenameTextBoxKeyDown"
                                 LostFocus="OnRenameTextBoxLostFocus"
                                 Loaded="OnRenameTextBoxLoaded">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                    <TextBlock Text="{Binding DisplayShell}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Type.Caption}">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorSecondaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Preview}"
                               FontFamily="{StaticResource Type.Family.Mono}"
                               FontSize="11"
                               LineHeight="14"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="60"
                               Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorSecondaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style x:Key="SessionListItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnSessionItemMouseDown" />
            <EventSetter Event="PreviewMouseMove" Handler="OnSessionItemMouseMove" />
            <Setter Property="AllowDrop" Value="True" />
            <EventSetter Event="Drop" Handler="OnSessionItemDrop" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Radius.Card}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Stretch" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <!-- Selected wins because it's declared after IsMouseOver. -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource Cmux.Selection.Brush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource GridLength.SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource GridLength.TitleBarHeight}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2"
                     Title=""
                     ShowMaximize="True" />

        <StackPanel Grid.Row="0" Grid.Column="0"
                    Orientation="Horizontal"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    IsHitTestVisible="False">
            <ui:FontIcon Glyph="&#xE756;"
                         FontFamily="{StaticResource Type.Family.Icons}"
                         FontSize="14"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0" />
            <TextBlock Text="cmux"
                       Style="{StaticResource Type.Caption}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource LayerFillColorAltBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ui:ListView Grid.Row="0"
                             x:Name="SessionList"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="{StaticResource Thickness.S08}"
                             ItemContainerStyle="{StaticResource SessionListItemStyle}"
                             ItemTemplate="{StaticResource SessionItemTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch"
                             AllowDrop="True"
                             SelectionChanged="OnSessionSelectionChanged" />

                <Border Grid.Row="1"
                        Padding="{StaticResource Thickness.S08}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:DropDownButton x:Name="NewSessionButton"
                                           Grid.Column="0"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left">
                            <ui:DropDownButton.Content>
                                <TextBlock Text="New session" />
                            </ui:DropDownButton.Content>
                            <ui:DropDownButton.Flyout>
                                <ContextMenu x:Name="NewSessionFlyout" />
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                        <ui:Button x:Name="SettingsButton"
                                   Grid.Column="1"
                                   Appearance="Transparent"
                                   ToolTip="Settings"
                                   MinWidth="32"
                                   Padding="6"
                                   Margin="4,0,0,0"
                                   Click="OnSettingsClick">
                            <ui:FontIcon Glyph="&#xE713;"
                                         FontFamily="{StaticResource Type.Family.Icons}"
                                         FontSize="14"
                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </ui:Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="TerminalHost"
              Grid.Row="1" Grid.Column="1" />

        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{DynamicResource LayerFillColorAltBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText"
                       Style="{StaticResource Type.Caption}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0" />
        </Border>
    </Grid>
</ui:FluentWindow>
