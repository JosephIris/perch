<ui:FluentWindow x:Class="CmuxWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="cmux"
        Icon="/Assets/cmux.ico"
        Height="640" Width="1040"
        MinHeight="360" MinWidth="640"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="Transparent">

    <!-- Real WPF title bar so the system caption buttons (min / max / close)
         are actually visible. We keep WPF-UI's TitleBar for that reason but
         drop the "cmux" title text — chrome stays minimal, matching the
         Claude desktop pattern. The sidebar toggle lives here so it stays
         clickable when the webview-side sidebar is collapsed.

         See docs/DESIGN-BIBLE.md "Vocabulary > Affordance" and
         "Sidebar pattern". -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Explicit Height so the title bar is no taller than the toggle +
             caption buttons need. WPF-UI's default is ~36–40px; shrinking to
             32 removes a visible strip of dead space below the controls. -->
        <ui:TitleBar Grid.Row="0"
                     Height="32"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Header>
                <!-- Icon row in the title bar. Today: sidebar toggle only.
                     Search / back / forward stay deferred until they have
                     real behavior to invoke. -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0">
                    <ui:Button x:Name="SidebarToggleBtn"
                               Appearance="Transparent"
                               Padding="4"
                               Margin="0"
                               ToolTip="Toggle sidebar (Ctrl+B)"
                               Click="OnSidebarToggleClick">
                        <ui:SymbolIcon Symbol="PanelLeft20"
                                       FontSize="14" />
                    </ui:Button>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>
        <Grid Grid.Row="1">
            <!-- Main WebView2 hosts the chrome (sidebar, workspace shell)
                 and all terminal panes via xterm.js. -->
            <wv2:WebView2 x:Name="Web"
                          DefaultBackgroundColor="Transparent" />

            <!-- Canvas overlay for URL panes. Each URL leaf in the pane
                 tree spawns a real WebView2 control here (managed by
                 MainWindow.xaml.cs), positioned via Canvas.Left/Top.
                 Background={x:Null} so empty regions don't block clicks
                 to the WebView2 underneath — only the WebView2 children
                 catch mouse events. -->
            <Canvas x:Name="UrlPaneOverlay"
                    Background="{x:Null}"
                    IsHitTestVisible="True" />
        </Grid>
    </Grid>
</ui:FluentWindow>
