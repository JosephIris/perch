<ui:FluentWindow x:Class="CmuxWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="cmux"
        Icon="/Assets/cmux.ico"
        Height="640" Width="1040"
        MinHeight="360" MinWidth="640"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="Transparent">

    <!-- All UI lives inside this WebView2. The WPF side is just the window
         chrome and the WebView2 host. ConPTY processes, the IPC layer, and
         persistence live in C#; the bridge is host_objects + PostWebMessage. -->
    <wv2:WebView2 x:Name="Web"
                  DefaultBackgroundColor="Transparent" />
</ui:FluentWindow>
