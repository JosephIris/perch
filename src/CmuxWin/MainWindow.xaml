<ui:FluentWindow x:Class="CmuxWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="cmux"
        Icon="/Assets/cmux.ico"
        Height="640" Width="1040"
        MinHeight="360" MinWidth="640"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="Transparent">

    <!-- Real WPF title bar so the system caption buttons (min / max / close)
         are actually visible. Putting them in HTML would require us to
         re-implement min/max/close via window commands and lose the system
         Aero-snap affordances. WPF-UI's TitleBar already integrates with
         ExtendsContentIntoTitleBar so Mica still reads through. The webview
         takes the rest of the window. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0"
                     Title="cmux"
                     ShowMaximize="True"
                     ShowMinimize="True" />
        <wv2:WebView2 x:Name="Web"
                      Grid.Row="1"
                      DefaultBackgroundColor="Transparent" />
    </Grid>
</ui:FluentWindow>
