<ui:FluentWindow x:Class="CmuxWin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CmuxWin"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Settings"
        Height="440" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="Transparent"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource GridLength.TitleBarHeight}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Settings"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Thickness.S16}">
            <StackPanel Orientation="Vertical">

                <!-- Font family -->
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Font family"
                                       Style="{StaticResource Type.Body}"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Used by all terminal panes."
                                       Style="{StaticResource Type.Caption}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox x:Name="FontFamilyBox"
                              MinWidth="180"
                              FontFamily="{StaticResource Type.Family}"
                              SelectionChanged="OnPreviewChanged" />
                </ui:CardControl>

                <!-- Font size -->
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Font size"
                                       Style="{StaticResource Type.Body}"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Point size 8–32. Applies to new panes (existing panes keep their size)."
                                       Style="{StaticResource Type.Caption}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:NumberBox x:Name="FontSizeBox"
                                  Minimum="8"
                                  Maximum="32"
                                  MinWidth="120"
                                  SpinButtonPlacementMode="Inline"
                                  ValueChanged="OnPreviewChanged" />
                </ui:CardControl>

                <!-- Live preview -->
                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource Radius.Card}"
                        Padding="16,12,16,12"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Preview"
                                   Style="{StaticResource Type.Caption}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <TextBlock x:Name="PreviewText"
                                   Text="PS C:\Users&gt; Get-Date  // ABCdef 0123"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Default shell -->
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Default shell"
                                       Style="{StaticResource Type.Body}"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Used when starting a new session. Existing sessions keep their shell."
                                       Style="{StaticResource Type.Caption}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox x:Name="ShellBox"
                              MinWidth="180" />
                </ui:CardControl>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="{StaticResource Thickness.S16}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button Content="Cancel"
                           Appearance="Secondary"
                           Margin="0,0,8,0"
                           Click="OnCancelClick" />
                <ui:Button Content="Save"
                           Appearance="Primary"
                           IsDefault="True"
                           Click="OnSaveClick" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
